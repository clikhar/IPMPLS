CRTNM_ENVIRONMENT=development
POSTGRES_PASSWORD=replace-with-a-long-random-password
CRTNM_DATABASE_URL=sqlite:///./crtnm.db
CRTNM_SECRET_KEY=replace-with-a-long-random-secret
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CRTNM_FERNET_KEY=replace-with-a-fernet-key
CRTNM_CORS_ORIGINS=http://localhost:5173
CRTNM_REDIS_URL=redis://localhost:6379/0
CRTNM_CELERY_BROKER_URL=redis://localhost:6379/1
CRTNM_CELERY_RESULT_BACKEND=redis://localhost:6379/2
CRTNM_RATE_LIMIT_PER_MINUTE=10
